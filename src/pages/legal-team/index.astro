---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import TeamModals from '../../components/TeamModals.astro';
import { partners, ofCounsel, staff, teamModals } from '../../data/team';
---

<BaseLayout title="Legal Team" activeNav="team">
  <main class="page-content" aria-label="Content">
    <div class="wrapper">
      <section id="lawyers" class="ourTeam u-py8 u-bgColor-gray200">
        <div class="o-grid o-grid--alignCenter">
          <header class="o-grid-cell u-mb5">
            <h1 class="u-txtCenter">Legal Team</h1>
          </header>
          {
            partners.map((p) => (
              <div class="o-grid-cell u-lg-size1of2">
                <div id={p.id} class="u-borderAll u-bgColor-gray100 u-borderColor-gray400 u-border1 u-mb5">
                  <div class="o-ratio o-ratio--4x3 u-mb3">
                    <a class="o-ratio-item" href={p.profileHref}>
                      <img
                        loading="lazy"
                        class="u-sizeFull u-hoverGrow o-ratio-item"
                        alt={p.name}
                        src={p.headshot}
                      />
                    </a>
                  </div>
                  <h3 class="u-bold u-txtCenter u-py3 u-mb1">{p.name}</h3>
                  <div class="o-box u-px5 u-pb5 u-pt2 u-txtSmaller">
                    <p>{p.shortBio}</p>
                    <div class="u-flex">
                      <a class="button button--primary u-size1of2 u-mr4" href={`mailto:${p.email}`}>
                        Email
                      </a>
                      <a class="button button--primary button--outline u-size1of2" href={p.profileHref}>
                        Read More
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </section>
      <section class="ourTeam u-py8 u-bgColor-gray300">
        <div class="o-grid o-grid--fulll o-grid--alignCenter">
          <header class="o-grid-cell u-mb5">
            <h2 class="u-txtCenter">Of Counsel</h2>
          </header>
          {
            ofCounsel.map((m) => (
              <div class="o-grid-cell u-md-size1of2 u-lg-size3of10">
                <div class="u-borderAll u-bgColor-gray100 u-borderColor-gray400 u-border1 u-mb5">
                  <div class="o-ratio o-ratio--4x3">
                    {m.modalId ? (
                      <a class="o-ratio-item" href={`#${m.modalId}`} data-modal="">
                        <img
                          loading="lazy"
                          class="u-sizeFull u-hoverGrow o-ratio-item"
                          alt={m.name}
                          src={m.headshot}
                        />
                      </a>
                    ) : (
                      <div class="o-ratio-item">
                        <img
                          loading="lazy"
                          class="u-sizeFull o-ratio-item"
                          alt={m.name}
                          src={m.headshot}
                        />
                      </div>
                    )}
                  </div>
                  <h3 class="u-h4 u-txtCenter u-py3">{m.name}</h3>
                </div>
              </div>
            ))
          }
        </div>
      </section>
      <section class="ourTeam u-py8 u-bgColor-gray200">
        <div class="o-grid o-grid--fulll o-grid--alignCenter">
          <header class="o-grid-cell u-mb5">
            <h2 class="u-txtCenter">Our Staff</h2>
          </header>
          {
            staff.map((s) => (
              <div class="o-grid-cell u-md-size1of2 u-lg-size3of12">
                <div class="u-borderAll u-bgColor-gray100 u-borderColor-gray400 u-border1 u-mb5">
                  <div class="o-ratio o-ratio--4x3">
                    <div class="o-ratio-item">
                      <img
                        loading="lazy"
                        class="u-sizeFull o-ratio-item"
                        alt={s.name}
                        src={s.headshot}
                      />
                    </div>
                  </div>
                  <h3 class="u-h4 u-txtCenter u-py3">{s.name}</h3>
                </div>
              </div>
            ))
          }
        </div>
      </section>
      <TeamModals modals={teamModals} />
      <CTASection />
    </div>
  </main>
</BaseLayout>
