---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { META_DESCRIPTIONS } from '../../consts';
---

<BaseLayout title="Contact Us" description={META_DESCRIPTIONS.contact} activeNav="contact">
  <main class="page-content" aria-label="Content">
    <div class="wrapper">
      <div class="aboutUs">
        <section class="u-bgColor-gray200 u-py8">
          <div class="o-grid o-grid--alignCenter">
            <header class="o-grid-cell u-mb5 u-lg-size8of12">
              <h1 class="u-txtCenter">Contact Us</h1>
              <p>
                If you need legal counsel in the Los Angeles area, Willoughby & Associates is here for you. Reach our
                Culver City office by phone or email, and let our decades of litigation experience support your case.
              </p>
            </header>
            <div class="o-grid-cell u-lg-size8of12">
              <div class="o-ratio o-ratio--16x9 u-mb5">
                <iframe
                  width="560"
                  height="315"
                  id="gmap_canvas"
                  title="Office location map"
                  src="https://maps.google.com/maps?q=200%20Corporate%20Pointe%2C%20Suite%20495%20Culver%20City%2C%20CA%2090230&t=&z=15&ie=UTF8&iwloc=&output=embed"
                  style="border:0"
                  loading="lazy"></iframe>
              </div>
            </div>
            <div class="o-grid o-grid--alignCenter">
              <div class="o-grid-cell u-lg-size8of12">
                <div class="u-flex u-mb3">
                  <div class="u-mr4">
                    <h3 class="u-h4 u-bold u-fontFamilySans">Address:</h3>
                  </div>
                  <div class="u-flexGrow1">
                    <address>
                      200 Corporate Pointe, Suite 495<br /> Culver City, CA 90230
                    </address>
                  </div>
                </div>
              </div>
              <div class="o-grid-cell u-lg-size8of12">
                <div class="u-flex u-mb3">
                  <div class="u-mr4">
                    <h3 class="u-h4 u-bold u-fontFamilySans">Phone:</h3>
                  </div>
                  <div class="u-flexGrow1">
                    <a href="tel:3106420600">(310) 642-0600</a>
                  </div>
                </div>
              </div>
              <div class="o-grid-cell u-lg-size8of12">
                <div class="u-flex u-mb3">
                  <div class="u-mr4">
                    <h3 class="u-h4 u-bold u-fontFamilySans">Fax:</h3>
                  </div>
                  <div class="u-flexGrow1">(310) 642-4710</div>
                </div>
              </div>
              <div class="o-grid-cell u-lg-size8of12">
                <div class="u-flex u-mb3">
                  <div class="u-mr4">
                    <h3 class="u-h4 u-bold u-fontFamilySans">Email:</h3>
                  </div>
                  <div class="u-flexGrow1">
                    <a href="mailto:receptionist@firmwilloughby.us">receptionist@firmwilloughby.us</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>
</BaseLayout>
