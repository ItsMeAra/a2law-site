---
import type { TeamModal } from '../data/team';

interface Props {
  modals: TeamModal[];
}

const { modals } = Astro.props;

function widthClass(id: string): string {
  return id === 'anthonyWilloughby' || id === 'anthonyWilloughby2' ? 'u-lg-size8of12' : 'u-lg-size6of12';
}
---

{
  modals.map((modal) => (
    <section id={modal.id} class:list={['bpModal', widthClass(modal.id)]}>
      <header class="bpModal-header">
        <h2 class="bpModal-title">{modal.title}</h2>
      </header>
      <div class="bpModal-body u-txtSmaller">
        {modal.paragraphs.some((p) => p.trim().length > 0) ? (
          modal.paragraphs
            .filter((p) => p.trim().length > 0)
            .map((p) => <p>{p}</p>)
        ) : (
          <p />
        )}
      </div>
      <footer class="bpModal-footer">
        <a class="button button--primary button--sm" href="#" rel="modal:close">
          Close
        </a>
      </footer>
    </section>
  ))
}
